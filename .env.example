# Telegram (Required)
TELEGRAM_TOKEN=your_bot_token_from_botfather
AUTHORIZED_USER_ID=your_telegram_user_id
TRADES_CHANNEL_ID=-1001234567890
LOGS_CHANNEL_ID=-1009876543210

# Paper Trading (Shimmer)
PAPER_ENABLED=true
SHIMMER_MOCK_MODE=true
SHIMMER_API_KEY=your_key_here_if_not_mock
PAPER_AUTO_TRADE=true
PAPER_TRADE_SIZE=10

# Live Trading (Polymarket) - Set to false if not using
LIVE_ENABLED=false
LIVE_AUTO_TRADE=false
POLYMARKET_PK=your_private_key_here
POLYMARKET_API_KEY=your_api_key
POLYMARKET_SECRET=your_secret
