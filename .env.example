# Live Trading (Polymarket Real Money) - Completely Independent
LIVE_ENABLED=false
POLYMARKET_PK=your_private_key_here
POLYMARKET_API_KEY=your_api_key
POLYMARKET_SECRET=your_secret
LIVE_AUTO_TRADE=false  # Separate control!
LIVE_TRADE_SIZE=5
LIVE_MAX_SIZE=50
