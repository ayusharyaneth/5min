# ═══════════════════════════════════════════════════════════
# TELEGRAM BOT CORE (REQUIRED)
# ═══════════════════════════════════════════════════════════

# Your bot token from @BotFather
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz
# Your personal Telegram User ID (from @userinfobot) - ONLY YOU CAN USE THIS BOT
AUTHORIZED_USER_ID=123456789
# Your Telegram Chat ID for personal notifications (from @userinfobot)
TELEGRAM_CHAT_ID=123456789
# Channel for trade notifications (create channel, add bot, get ID from @userinfobot)
TRADES_CHANNEL_ID=-1001234567890
# Channel for logs/errors/startup/shutdown alerts
LOGS_CHANNEL_ID=-1009876543210


# ═══════════════════════════════════════════════════════════
# PAPER TRADING (Shimmer Simulation) - FREE TO USE
# ═══════════════════════════════════════════════════════════

# Enable paper trading? (true/false)
PAPER_ENABLED=true
# Auto-trade on paper? (true/false) - DEFAULT IS TRUE NOW
PAPER_AUTO_TRADE=true
# Trade size in virtual USD
PAPER_TRADE_SIZE=10
# Shimmer API key (optional if using mock mode)
SHIMMER_API_KEY=
# Mock mode: true = fake/simulated markets, false = real Shimmer testnet
SHIMMER_MOCK_MODE=true
# Starting virtual balance
INITIAL_BALANCE=10000


# ═══════════════════════════════════════════════════════════
# LIVE TRADING (Polymarket Real Money) - ⚠️ USE WITH CAUTION
# ═══════════════════════════════════════════════════════════

# Enable live trading? (true/false) - SET TO false IF NOT USING REAL MONEY
LIVE_ENABLED=false
# ⚠️  AUTO-TRADE ON LIVE IS DANGEROUS - DEFAULT IS TRUE NOW, SET TO false IF UNSURE
LIVE_AUTO_TRADE=false
# Trade size in real USDC
LIVE_TRADE_SIZE=5
# Maximum trade size limit (safety)
LIVE_MAX_SIZE=50
# Your wallet private key (0x...) - NEVER SHARE THIS
POLYMARKET_PK=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef
# Polymarket API credentials (get from Polymarket dashboard)
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_SECRET=your_secret_here


# ═══════════════════════════════════════════════════════════
# TRADING PARAMETERS
# ═══════════════════════════════════════════════════════════

# How often to check for opportunities (seconds)
CHECK_INTERVAL=1
# Minimum confidence % to execute trade (0.75 = 75%)
MIN_CONFIDENCE=0.75
