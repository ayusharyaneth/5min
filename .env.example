# Required for Bot Control
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Paper Trading (Shimmer Simulation) - Independent
PAPER_ENABLED=true
SHIMMER_API_KEY=optional_shimmer_key
SHIMMER_MOCK_MODE=true  # true=fake markets, false=real shimmer paper api
PAPER_AUTO_TRADE=false
